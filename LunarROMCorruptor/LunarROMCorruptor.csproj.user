<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="Current" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <ProjectView>ProjectFiles</ProjectView>
    <PublishUrlHistory>publish\</PublishUrlHistory>
    <InstallUrlHistory />
    <SupportUrlHistory />
    <UpdateUrlHistory />
    <BootstrapperUrlHistory />
    <ErrorReportUrlHistory />
    <FallbackCulture>en-US</FallbackCulture>
    <VerifyUploadedFiles>false</VerifyUploadedFiles>
  </PropertyGroup>
  <ItemGroup>
    <Compile Update="Forms\CorruptionEngineOptions.cs">
      <SubType>Form</SubType>
    </Compile>
    <Compile Update="Forms\CorruptionQueueForm.cs">
      <SubType>Form</SubType>
    </Compile>
    <Compile Update="Forms\InputBox.cs">
      <SubType>Form</SubType>
    </Compile>
    <Compile Update="Forms\MainCorruptionForm.cs">
      <SubType>Form</SubType>
    </Compile>
    <Compile Update="Forms\SelectProcess.cs">
      <SubType>Form</SubType>
    </Compile>
    <Compile Update="Forms\StashEditor.cs">
      <SubType>Form</SubType>
    </Compile>
  </ItemGroup>
</Project>